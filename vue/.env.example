# Yandex Maps JavaScript API key. Visible in browser, restrict by HTTP Referer in Yandex dashboard.
VITE_YANDEX_MAPS_API_KEY=

# Optional: separate Geosuggest/Suggest API key for Yandex search suggestions.
VITE_YANDEX_SUGGEST_API_KEY=

# release for normal work, debug when diagnosing Yandex Maps API errors.
VITE_YANDEX_MAPS_MODE=release

# Optional: free road-route fallback. Leave empty to use public OSRM.
VITE_OSRM_ROUTE_URL=https://router.project-osrm.org
